<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Apply for Job</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#0f172a;
    color:white;
    min-height:100vh;
}

/* NAVBAR */

.navbar{
    background:#111827 !important;
    padding:18px 0;
    border-bottom:1px solid rgba(255,255,255,.08);
}

.navbar-brand{
    font-size:1.8rem;
    font-weight:700;
}

/* HERO */

.hero{
    text-align:center;
    padding:70px 20px 40px;
    position:relative;
}

.hero::before{
    content:"";
    position:absolute;
    width:450px;
    height:450px;
    background:#7c3aed;
    filter:blur(180px);
    opacity:.25;
    top:-150px;
    left:50%;
    transform:translateX(-50%);
    z-index:-1;
}

.page-title{
    font-size:3.2rem;
    font-weight:800;
}

.gradient-text{
    background:linear-gradient(90deg,#60a5fa,#a855f7);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.hero-text{
    color:#cbd5e1;
    margin-top:15px;
}

/* FORM */

.form-card{

    background:#1e293b;

    border-radius:20px;

    padding:35px;

    box-shadow:0 0 25px rgba(0,0,0,.3);

}

.form-card:hover{

    box-shadow:0 0 35px rgba(139,92,246,.25);

}

.form-label{

    color:white;

    font-weight:600;

}

.form-control{

    background:#0f172a;

    border:1px solid rgba(255,255,255,.08);

    color:white;

    padding:12px;

}

.form-control:focus{

    background:#0f172a;

    color:white;

    border-color:#8b5cf6;

    box-shadow:none;

}

.form-control::placeholder{

    color:#94a3b8;

}

.submit-btn{

    background:linear-gradient(90deg,#3b82f6,#8b5cf6);

    border:none;

    font-weight:600;

    padding:12px;

}

.submit-btn:hover{

    opacity:.9;

}

footer{

    margin-top:80px;

    background:#111827;

    padding:40px;

    text-align:center;

    border-top:1px solid rgba(255,255,255,.08);

}

</style>

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark">

<div class="container">

<a class="navbar-brand" href="/">

💼 Job Portal

</a>

<div>

<a href="/" class="btn btn-outline-light me-2">

Home

</a>

<a href="/jobs" class="btn btn-outline-light">

View Jobs

</a>

</div>

</div>

</nav>

<section class="hero">

<h1 class="page-title">

Apply for

<span class="gradient-text">

<%= job.title %>

</span>

</h1>

<p class="hero-text">

Complete the application form below and upload your resume.

</p>

</section>

<div class="container">

<div class="row justify-content-center">

<div class="col-lg-7">

<div class="form-card">

<form
action="/apply/<%= job._id %>"
method="POST"
enctype="multipart/form-data">

<div class="mb-4">

<label class="form-label">

Full Name

</label>

<input
type="text"
name="applicantName"
class="form-control"
placeholder="Enter your full name"
required>

</div>

<div class="mb-4">

<label class="form-label">

Email Address

</label>

<input
type="email"
name="email"
class="form-control"
placeholder="Enter your email"
required>

</div>

<div class="mb-4">

<label class="form-label">

Phone Number

</label>

<input
type="text"
name="phone"
class="form-control"
placeholder="Enter your phone number"
required>

</div>

<div class="mb-4">

<label class="form-label">

Upload Resume (PDF)

</label>

<input
type="file"
name="resume"
class="form-control"
accept=".pdf"
required>

</div>

<button
type="submit"
class="btn submit-btn w-100">

🚀 Submit Application

</button>

<a
href="/jobs"
class="btn btn-outline-light w-100 mt-3">

← Back to Jobs

</a>

</form>

</div>

</div>

</div>

</div>

<footer>

<h5>© 2026 Job Portal</h5>

<p class="text-light mt-3">

ALL RIGHTS RESERVED.

</p>

<p class="text-secondary">

Helping candidates connect with top companies.

</p>

</footer>

</body>

</html>