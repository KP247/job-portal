```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Edit Job</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#0f172a;
    color:white;
    min-height:100vh;
}

/* NAVBAR */

.navbar{
    background:#111827 !important;
    padding:18px 0;
    border-bottom:1px solid rgba(255,255,255,.08);
}

.navbar-brand{
    font-size:1.8rem;
    font-weight:700;
}

/* HERO */

.hero{
    text-align:center;
    padding:70px 20px 40px;
    position:relative;
}

.hero::before{
    content:"";
    position:absolute;
    width:450px;
    height:450px;
    background:#7c3aed;
    filter:blur(180px);
    opacity:.25;
    top:-150px;
    left:50%;
    transform:translateX(-50%);
    z-index:-1;
}

.page-title{
    font-size:3.5rem;
    font-weight:800;
}

.gradient-text{
    background:linear-gradient(
        90deg,
        #60a5fa,
        #a855f7
    );
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.hero-text{
    color:#cbd5e1;
    margin-top:15px;
}

/* FORM CARD */

.form-card{
    background:#1e293b;
    border-radius:20px;
    padding:35px;
    box-shadow:0 0 25px rgba(0,0,0,.3);
}

.form-card:hover{
    box-shadow:0 0 35px rgba(139,92,246,.25);
}

/* INPUTS */

.form-label{
    color:white;
    font-weight:600;
}

.form-control{
    background:#0f172a;
    border:1px solid rgba(255,255,255,.08);
    color:white;
    padding:12px;
}

.form-control:focus{
    background:#0f172a;
    color:white;
    border-color:#8b5cf6;
    box-shadow:none;
}

.form-control::placeholder{
    color:#94a3b8;
}

/* BUTTONS */

.update-btn{
    background:linear-gradient(
        90deg,
        #f59e0b,
        #f97316
    );
    border:none;
    color:white;
    padding:12px;
    font-weight:600;
}

.update-btn:hover{
    opacity:.9;
    color:white;
}

.back-btn{
    border:1px solid rgba(255,255,255,.15);
}

/* INFO CARD */

.info-card{
    background:#1e293b;
    border-radius:16px;
    padding:20px;
    text-align:center;
    margin-bottom:25px;
}

/* FOOTER */

footer{
    margin-top:80px;
    background:#111827;
    padding:40px;
    text-align:center;
    border-top:1px solid rgba(255,255,255,.08);
}

@media(max-width:768px){

.page-title{
    font-size:2.5rem;
}

.navbar-brand{
    font-size:1.4rem;
}

}

</style>
</head>

<body>

<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg navbar-dark">

<div class="container">

<a class="navbar-brand" href="/">
    💼 Job Portal
</a>

<div>

<a href="/" class="btn btn-outline-light me-2">
    Home
</a>

<% if(isAdmin) { %>

<a href="/add-job" class="btn btn-outline-light me-2">
    Add Job
</a>

<a href="/logout" class="btn btn-danger">
    Logout
</a>

<% } %>

<a href="/jobs" class="btn btn-outline-light">
    View Jobs
</a>

</div>

</div>

</nav>

<!-- HERO -->

<section class="hero">

<h1 class="page-title">
    Edit
    <span class="gradient-text">
        Job Details
    </span>
</h1>

<p class="hero-text">
    Update the job information and keep listings up to date.
</p>

</section>

<!-- FORM -->

<div class="container">

<div class="row justify-content-center">

<div class="col-lg-7">

<div class="info-card">

<h5>✏️ Update Job Information</h5>

<p class="text-secondary mb-0">
Modify the details below and save the changes.
</p>

</div>

<div class="form-card">

<form action="/update-job/<%= job._id %>" method="POST">

<div class="mb-4">

<label class="form-label">
    Job Title
</label>

<input
type="text"
name="title"
class="form-control"
value="<%= job.title %>"
required>

</div>

<div class="mb-4">

<label class="form-label">
    Company Name
</label>

<input
type="text"
name="company"
class="form-control"
value="<%= job.company %>"
required>

</div>

<div class="mb-4">

<label class="form-label">
    Location
</label>

<input
type="text"
name="location"
class="form-control"
value="<%= job.location %>"
required>

</div>

<button
type="submit"
class="btn update-btn w-100">

🔄 Update Job

</button>

<a
href="/jobs"
class="btn btn-outline-light w-100 mt-3 back-btn">

📋 Back to Jobs

</a>

</form>

</div>

</div>

</div>

</div>

<!-- FOOTER -->

<footer>

<h5>© 2026 Job Portal</h5>

<p class="text-light mt-3">
ALL RIGHTS RESERVED. 
</p>

<p class="text-secondary">
Helping candidates connect with top companies.
</p>

</footer>

</body>
</html>
```
