<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            background:linear-gradient(135deg,#07142c,#0b1e46);
            color:white;
            min-height:100vh;
        }

        .navbar{
            background:rgba(255,255,255,.04);
            backdrop-filter:blur(10px);
        }

        .dashboard-title{
            font-size:3rem;
            font-weight:700;
        }

        .stat-card{

            border:none;
            border-radius:18px;
            padding:30px;
            text-align:center;

            transition:.3s ease;

            box-shadow:0 10px 25px rgba(0,0,0,.25);

        }

        .stat-card:hover{

            transform:translateY(-8px);

            box-shadow:0 20px 35px rgba(0,0,0,.45);

        }

        .stat-card h1{

            font-size:2.5rem;

        }

        .stat-card h2{

            font-weight:700;

            margin-top:10px;

        }

        .stat-card p{

            margin:0;

            opacity:.9;

            font-size:18px;

        }

        .table{

            border-radius:15px;

            overflow:hidden;

        }

        .table thead{

            background:#122850;

        }

        .table tbody tr:hover{

            background:#1c3767;

        }

        .section-title{

            font-weight:700;

        }

    </style>

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark border-bottom mb-5">

<div class="container">

<a class="navbar-brand fw-bold fs-3" href="/">

💼 Job Portal

</a>

<div>

<a href="/" class="btn btn-outline-light me-2">

Home

</a>

<a href="/jobs" class="btn btn-outline-light me-2">

Jobs

</a>

<a href="/admin/dashboard" class="btn btn-info me-2">

Dashboard

</a>

<a href="/logout" class="btn btn-danger">

Logout

</a>

</div>

</div>

</nav>

<div class="container">

<h1 class="dashboard-title text-center mb-5">

📊 Admin Dashboard

</h1>

<div class="row g-4">

<div class="col-md-4">

<div class="stat-card bg-primary text-white">

<h1>💼</h1>

<h2><%= totalJobs %></h2>

<p>Total Jobs</p>

</div>

</div>

<div class="col-md-4">

<div class="stat-card bg-success text-white">

<h1>📄</h1>

<h2><%= totalApplications %></h2>

<p>Total Applications</p>

</div>

</div>

<div class="col-md-4">

<div class="stat-card bg-warning text-dark">

<h1>⏳</h1>

<h2><%= pending %></h2>

<p>Pending</p>

</div>

</div>

<div class="col-md-6">

<div class="stat-card bg-info text-white">

<h1>✅</h1>

<h2><%= selected %></h2>

<p>Selected</p>

</div>

</div>

<div class="col-md-6">

<div class="stat-card bg-danger text-white">

<h1>❌</h1>

<h2><%= rejected %></h2>

<p>Rejected</p>

</div>

</div>

</div>

<hr class="my-5">

<h2 class="section-title mb-4">

📝 Recent Applications

</h2>

<div class="table-responsive">

<table class="table table-dark table-hover table-striped align-middle">

<thead>

<tr>

<th>Name</th>

<th>Job</th>

<th>Status</th>

</tr>

</thead>

<tbody>

<% recentApplications.forEach(application => { %>

<tr>

<td>

<%= application.applicantName %>

</td>

<td>

<%= application.jobId ? application.jobId.title : "Job Deleted" %>

</td>

<td>

<% if(application.status==="Pending"){ %>

<span class="badge bg-warning text-dark">

Pending

</span>

<% }else if(application.status==="Selected"){ %>

<span class="badge bg-success">

Selected

</span>

<% }else{ %>

<span class="badge bg-danger">

Rejected

</span>

<% } %>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>