<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Job Portal</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#0f172a;
    color:white;
    min-height:100vh;
    overflow-x:hidden;
}

/* NAVBAR */

.navbar{
    background:#111827 !important;
    padding:18px 0;
    border-bottom:1px solid rgba(255,255,255,0.08);
}

.navbar-brand{
    font-size:1.8rem;
    font-weight:700;
}

/* HERO */

.hero{
    position:relative;
    text-align:center;
    padding:120px 20px 80px;
}

.hero::before{
    content:"";
    position:absolute;
    width:500px;
    height:500px;
    background:#7c3aed;
    filter:blur(180px);
    opacity:0.25;
    top:-150px;
    left:50%;
    transform:translateX(-50%);
    z-index:-1;
}

.hero-title{
    font-size:4.5rem;
    font-weight:800;
    line-height:1.1;
}

.gradient-text{
    background:linear-gradient(
        90deg,
        #60a5fa,
        #a855f7
    );
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.hero-text{
    color:#cbd5e1;
    font-size:1.2rem;
    max-width:700px;
    margin:auto;
}

/* BUTTONS */

.glow-btn{
    background:linear-gradient(
        90deg,
        #3b82f6,
        #8b5cf6
    );
    color:white;
    text-decoration:none;
    padding:12px 28px;
    border-radius:10px;
    font-weight:600;
    display:inline-block;
}

.glow-btn:hover{
    opacity:.9;
    color:white;
}

/* SEARCH BAR */

.search-box{
    background:#1e293b;
    border-radius:18px;
    padding:20px;
    box-shadow:0 0 25px rgba(0,0,0,.3);
}

.search-box input{
    background:#0f172a;
    border:none;
    color:white;
}

.search-box input:focus{
    background:#0f172a;
    color:white;
    box-shadow:none;
}

/* STATS */

.stats-card{
    background:#1e293b;
    border-radius:16px;
    padding:30px;
    text-align:center;
    box-shadow:0 0 25px rgba(139,92,246,.15);
    transition:.3s;
}

.stats-card:hover{
    transform:translateY(-6px);
}

.stats-card h2{
    font-weight:700;
}

/* SKILLS */

.skill-pill{
    display:inline-block;
    padding:12px 22px;
    margin:8px;
    border-radius:30px;
    background:#1e293b;
    border:1px solid rgba(255,255,255,.08);
    transition:.3s;
}

.skill-pill:hover{
    background:#334155;
    transform:translateY(-3px);
}

/* CARDS */

.feature-card{
    background:#1e293b;
    border-radius:16px;
    padding:30px;
    text-align:center;
    transition:.3s;
    height:100%;
    box-shadow:0 0 20px rgba(0,0,0,.2);
}

.feature-card:hover{
    transform:translateY(-8px);
}

/* SECTION TITLE */

.section-title{
    text-align:center;
    margin-bottom:40px;
    font-weight:700;
}

/* FOOTER */

footer{
    background:#111827;
    margin-top:80px;
    padding:40px 20px;
    text-align:center;
    border-top:1px solid rgba(255,255,255,.08);
}

/* MOBILE */

@media(max-width:768px){

.hero-title{
    font-size:2.8rem;
}

.navbar-brand{
    font-size:1.4rem;
}

}

</style>

</head>
<body>

<!-- NAVBAR -->

<nav class="navbar navbar-expand-lg navbar-dark">
<div class="container">

<a class="navbar-brand" href="/">
    💼 Job Portal
</a>

<div>
    <a href="/" class="btn btn-outline-light me-2">
        Home
    </a>

   <% if(isAdmin) { %>

<a href="/add-job" class="btn btn-outline-light me-2">
    Add Job
</a>

<% } %>

    <a href="/jobs" class="btn btn-outline-light">
        View Jobs
    </a>

<% if(isAdmin) { %>

<a href="/logout" class="btn btn-danger">
    Logout
</a>

<% } else { %>

<a href="/admin/login" class="btn btn-success">
    Admin Login
</a>

<% } %>



</div>

</div>
</nav>

<!-- HERO -->

<section class="hero">

<h1 class="hero-title">
    Find Your Next
    <span class="gradient-text">
        Career Opportunity
    </span>
</h1>

<p class="hero-text mt-4">
    Discover jobs from top companies and manage your applications effortlessly.
</p>

<!-- SEARCH -->

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="search-box">

                <div class="row g-3">

                    <div class="col-md-5">
                        <input
                        type="text"
                        class="form-control"
                        placeholder="Job title or keyword">
                    </div>

                    <div class="col-md-4">
                        <input
                        type="text"
                        class="form-control"
                        placeholder="Location">
                    </div>

                    <div class="col-md-3">
                        <button class="btn btn-primary w-100">
                            Search Jobs
                        </button>
                    </div>

                </div>

            </div>

        </div>
    </div>
</div>

<div class="mt-5">

<a href="/jobs" class="glow-btn me-3">
    Browse Jobs
</a>

<a href="/add-job" class="btn btn-success">
    Post a Job
</a>

</div>

</section>

<!-- STATS -->

<div class="container">

<div class="row">

<div class="col-md-4 mb-4">
<div class="stats-card">
<h2>250+</h2>
<p>Active Jobs</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="stats-card">
<h2>80+</h2>
<p>Hiring Companies</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="stats-card">
<h2>1500+</h2>
<p>Applications Submitted</p>
</div>
</div>

</div>

</div>

<!-- SKILLS -->

<div class="container text-center mt-5">

<h2 class="section-title">
    Popular Skills
</h2>

<span class="skill-pill">Java</span>
<span class="skill-pill">Python</span>
<span class="skill-pill">Salesforce</span>
<span class="skill-pill">Node.js</span>
<span class="skill-pill">MongoDB</span>
<span class="skill-pill">React</span>

</div>

<!-- FEATURED JOBS -->

<div class="container mt-5">

<h2 class="section-title">
    Featured Jobs
</h2>

<div class="row">

<div class="col-md-4 mb-4">
<div class="feature-card">
<h4>Frontend Developer</h4>
<p class="text-secondary">Google</p>
<p>₹8 - ₹12 LPA</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="feature-card">
<h4>Salesforce Developer</h4>
<p class="text-secondary">Infosys</p>
<p>₹6 - ₹10 LPA</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="feature-card">
<h4>Java Developer</h4>
<p class="text-secondary">TCS</p>
<p>₹5 - ₹8 LPA</p>
</div>
</div>

</div>

</div>

<!-- FEATURES -->

<div class="container mt-5">

<h2 class="section-title">
    Why Choose Us
</h2>

<div class="row">

<div class="col-md-4 mb-4">
<div class="feature-card">
<h1>⚡</h1>
<h4>Fast Search</h4>
<p>Find jobs instantly using smart search and filtering.</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="feature-card">
<h1>💼</h1>
<h4>Job Management</h4>
<p>Create, update and manage job postings efficiently.</p>
</div>
</div>

<div class="col-md-4 mb-4">
<div class="feature-card">
<h1>☁️</h1>
<h4>Cloud Database</h4>
<p>Securely store job information using MongoDB Atlas.</p>
</div>
</div>

</div>

</div>

<!-- COMPANIES -->

<div class="container mt-5 text-center">

<h2 class="section-title">
    Trusted Companies
</h2>

<div class="d-flex flex-wrap justify-content-center gap-3">

<div class="stats-card px-4 py-3">Google</div>
<div class="stats-card px-4 py-3">Microsoft</div>
<div class="stats-card px-4 py-3">Amazon</div>
<div class="stats-card px-4 py-3">Infosys</div>
<div class="stats-card px-4 py-3">TCS</div>

</div>

</div>

<!-- FOOTER -->

<footer>

<h5>© 2026 Job Portal</h5>

<p class="text-light mt-3">
ALL RIGHTS RESERVED. 
<br>DESIGNED AND DEVELOPED BY KRISHAN PAL SINGH.
</p>

<p class="text-secondary">
Helping candidates connect with top companies.
</p>

</footer>

</body>
</html>